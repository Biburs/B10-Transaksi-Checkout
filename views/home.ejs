<!--
  View: home.ejs
  Lokasi: views/home.ejs
  Fungsi: Dashboard setelah login
  Variabel yang dibutuhkan (di-pass dari indexController.home):
    - title           (string)  : "Dashboard"
    - user            (string)  : nama user yang login
    - userRole        (string)  : 'pegawai' | 'admin_logistik' | 'admin'
    - stats           (object)  : { pending, approved, rejected, fulfilled, cancelled } - jumlah per status
    - recentRequests  (array)   : 5 permintaan terakhir milik user
                                  format: [{ id, request_number, request_date, status, total_items }]
-->

<%- include('partials/head', { title: title }) %>

<body class="bg-background">
  <%- include('partials/sidebar', { user: user, userRole: userRole, activeMenu: 'dashboard' }) %>

  <main id="content">
    <%- include('partials/topbar', {
      pageTitle: 'Dashboard',
      pageSubtitle: 'Selamat datang, ' + user + '!'
    }) %>

    <div class="p-6 space-y-6">

      <!-- ===== STATISTIK PERMINTAAN ===== -->
      <section>
        <h2 class="text-lg font-semibold mb-4">
          <% if (userRole === 'pegawai') { %>
            Ringkasan Permintaan Saya
          <% } else { %>
            Ringkasan Permintaan Masuk
          <% } %>
        </h2>

        <div class="grid grid-cols-2 gap-4">

          <!-- Card: Pending -->
          <div class="card p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-muted-foreground">Menunggu</p>
                <p class="text-3xl font-bold mt-1"><%= stats.pending || 0 %></p>
              </div>
              <div class="size-10 rounded-full bg-yellow-100 text-yellow-700 flex items-center justify-center dark:bg-yellow-950 dark:text-yellow-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10" />
                  <polyline points="12 6 12 12 16 14" />
                </svg>
              </div>
            </div>
          </div>

          <!-- Card: Approved -->
          <div class="card p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-muted-foreground">Disetujui</p>
                <p class="text-3xl font-bold mt-1"><%= stats.approved || 0 %></p>
              </div>
              <div class="size-10 rounded-full bg-blue-100 text-blue-700 flex items-center justify-center dark:bg-blue-950 dark:text-blue-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </div>
            </div>
          </div>

          <!-- Card: Fulfilled -->
          <div class="card p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-muted-foreground">Selesai</p>
                <p class="text-3xl font-bold mt-1"><%= stats.fulfilled || 0 %></p>
              </div>
              <div class="size-10 rounded-full bg-green-100 text-green-700 flex items-center justify-center dark:bg-green-950 dark:text-green-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="20" height="14" x="2" y="7" rx="2" />
                  <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />
                </svg>
              </div>
            </div>
          </div>

          <!-- Card: Rejected -->
          <div class="card p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-muted-foreground">Ditolak</p>
                <p class="text-3xl font-bold mt-1"><%= stats.rejected || 0 %></p>
              </div>
              <div class="size-10 rounded-full bg-red-100 text-red-700 flex items-center justify-center dark:bg-red-950 dark:text-red-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="18" y1="6" x2="6" y2="18" />
                  <line x1="6" y1="6" x2="18" y2="18" />
                </svg>
              </div>
            </div>
          </div>

        </div>
      </section>

      <!-- ===== AKSI CEPAT (hanya untuk pegawai) ===== -->
      <% if (userRole === 'pegawai') { %>
        <section class="card p-6">
          <div class="flex items-center justify-between flex-wrap gap-4">
            <div>
              <h3 class="text-lg font-semibold">Butuh barang untuk pekerjaan Anda?</h3>
              <p class="text-sm text-muted-foreground mt-1">
                Ajukan permintaan barang habis pakai (ATK, kertas, tinta, dll).
                Admin Logistik akan meninjau permintaan Anda.
              </p>
            </div>
            <a href="/permintaan/baru" class="btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
                <path d="M12 5v14" /><path d="M5 12h14" />
              </svg>
              Buat Permintaan Baru
            </a>
          </div>
        </section>
      <% } %>

      <!-- ===== PERMINTAAN TERAKHIR ===== -->
      <section>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold">
            <% if (userRole === 'pegawai') { %>
              Permintaan Terakhir Saya
            <% } else { %>
              Permintaan Terakhir Masuk
            <% } %>
          </h2>
          <% if (userRole === 'pegawai') { %>
            <a href="/permintaan" class="text-sm text-primary hover:underline">Lihat semua →</a>
          <% } else { %>
            <a href="/admin/permintaan" class="text-sm text-primary hover:underline">Lihat semua →</a>
          <% } %>
        </div>

        <div class="card overflow-hidden">
          <% if (recentRequests && recentRequests.length > 0) { %>
            <table class="table w-full">
              <thead>
                <tr>
                  <th>No. Permintaan</th>
                  <th>Tanggal</th>
                  <th>Jumlah Item</th>
                  <th>Status</th>
                  <th class="text-right">Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% recentRequests.forEach(function(r) { %>
                  <tr>
                    <td class="font-medium"><%= r.request_number %></td>
                    <td><%= new Date(r.request_date).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %></td>
                    <td><%= r.total_items %> item</td>
                    <td>
                      <%
                        const statusColors = {
                          pending:   'bg-yellow-100 text-yellow-800 dark:bg-yellow-950 dark:text-yellow-300',
                          approved:  'bg-blue-100 text-blue-800 dark:bg-blue-950 dark:text-blue-300',
                          rejected:  'bg-red-100 text-red-800 dark:bg-red-950 dark:text-red-300',
                          fulfilled: 'bg-green-100 text-green-800 dark:bg-green-950 dark:text-green-300',
                          cancelled: 'bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-300'
                        };
                        const statusLabels = {
                          pending: 'Menunggu',
                          approved: 'Disetujui',
                          rejected: 'Ditolak',
                          fulfilled: 'Selesai',
                          cancelled: 'Dibatalkan'
                        };
                      %>
                      <span class="badge <%= statusColors[r.status] || 'bg-gray-100 text-gray-800' %>">
                        <%= statusLabels[r.status] || r.status %>
                      </span>
                    </td>
                    <td class="text-right">
                      <% if (userRole === 'pegawai') { %>
                        <a href="/permintaan/<%= r.id %>" class="text-sm text-primary hover:underline">Detail</a>
                      <% } else { %>
                        <a href="/admin/permintaan/<%= r.id %>" class="text-sm text-primary hover:underline">Detail</a>
                      <% } %>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } else { %>
            <div class="p-12 text-center text-muted-foreground">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-3 opacity-50">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
              </svg>
              <p class="text-sm">Belum ada permintaan.</p>
            </div>
          <% } %>
        </div>
      </section>

    </div>
  </main>

<%- include('partials/footer') %>

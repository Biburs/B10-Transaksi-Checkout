<!--
  View: permintaan/detail.ejs
  Lokasi: views/permintaan/detail.ejs
  Fungsi: Tampilkan detail satu permintaan barang milik pegawai
  Variabel dari controller:
    - title            (string)  : "Detail REQ-XXXX"
    - user             (string)  : nama user
    - userRole         (string)  : 'pegawai'
    - header           (object)  : data header permintaan + pemohon
    - details          (array)   : daftar item permintaan
    - approvals        (array)   : riwayat keputusan admin (bisa kosong)
    - totalItems       (number)  : jumlah baris item
    - totalQuantity    (number)  : total kuantitas semua item
-->

<%- include('../partials/head', { title: title }) %>

<body class="bg-background">
  <%- include('../partials/sidebar', { user: user, userRole: userRole, activeMenu: 'permintaan' }) %>

  <main id="content">
    <%- include('../partials/topbar', {
      pageTitle: header.request_number,
      pageSubtitle: 'Detail permintaan barang'
    }) %>

    <div class="p-6 space-y-6 max-w-5xl">

                <!-- ===== Banner Sukses (kalau habis edit/batal) ===== -->
        <% if (typeof updated !== 'undefined' && updated) { %>
            <div class="card p-4 border-l-4 border-green-500 bg-green-50 dark:bg-green-950">
            <div class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600 dark:text-green-400 mt-0.5 shrink-0">
                <polyline points="20 6 9 17 4 12" />
                </svg>
                <div>
                <p class="font-semibold text-green-900 dark:text-green-100">Permintaan berhasil diperbarui</p>
                <p class="text-sm text-green-700 dark:text-green-300 mt-1">Perubahan Anda sudah tersimpan.</p>
                </div>
            </div>
            </div>
        <% } %>

        <% if (typeof cancelled !== 'undefined' && cancelled) { %>
            <div class="card p-4 border-l-4 border-gray-500 bg-gray-50 dark:bg-gray-900">
            <div class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-600 dark:text-gray-400 mt-0.5 shrink-0">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
                </svg>
                <div>
                <p class="font-semibold text-gray-900 dark:text-gray-100">Permintaan telah dibatalkan</p>
                <p class="text-sm text-gray-700 dark:text-gray-300 mt-1">Status permintaan sekarang menjadi "Dibatalkan".</p>
                </div>
            </div>
            </div>
        <% } %>

      <!-- ===== Breadcrumb / Back ===== -->
      <div class="flex items-center justify-between flex-wrap gap-3">
        <a href="/permintaan" class="text-sm text-muted-foreground hover:text-foreground inline-flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6" />
          </svg>
          Kembali ke daftar permintaan
        </a>

        <!-- Action buttons (tergantung status) -->
        <div class="flex items-center gap-2">
        <% if (header.status === 'pending') { %>
            
        <!-- Edit & Batal: hanya untuk status pending -->
        <a href="/permintaan/<%= header.id %>/edit" class="btn-outline">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
            </svg>
            Edit
        </a>

        <!-- Tombol Batalkan: pakai form POST dengan konfirmasi JS -->
        <form action="/permintaan/<%= header.id %>/batal" method="POST" 
                onsubmit="return confirm('Anda yakin ingin membatalkan permintaan ini? Tindakan ini tidak bisa dibatalkan.');"
                style="display: inline;">
            <button type="submit" class="btn-outline text-red-600 dark:text-red-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
            Batalkan
            </button>
        </form>
        <% } %>

        <!-- Cetak: tersedia untuk semua status (akan dibuat di F5) -->
                <% if (header.status === 'approved' || header.status === 'fulfilled') { %>
          <a href="/permintaan/<%= header.id %>/cetak" class="btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
              <polyline points="6 9 6 2 18 2 18 9" />
              <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
              <rect width="12" height="8" x="6" y="14" />
            </svg>
            Cetak PDF
          </a>
        <% } %>
                </div>
              </div>

      <!-- ===== Card 1: Informasi Header ===== -->
      <div class="card p-6">
        <div class="flex items-start justify-between flex-wrap gap-4 mb-4">
          <div>
            <h2 class="text-base font-semibold">Informasi Permintaan</h2>
            <p class="text-sm text-muted-foreground mt-1">Detail header dan status persetujuan</p>
          </div>
          <%
            const statusColors = {
              pending:   'bg-yellow-100 text-yellow-800 dark:bg-yellow-950 dark:text-yellow-300',
              approved:  'bg-blue-100 text-blue-800 dark:bg-blue-950 dark:text-blue-300',
              rejected:  'bg-red-100 text-red-800 dark:bg-red-950 dark:text-red-300',
              fulfilled: 'bg-green-100 text-green-800 dark:bg-green-950 dark:text-green-300',
              cancelled: 'bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-300'
            };
            const statusLabels = {
              pending: 'Menunggu Persetujuan',
              approved: 'Disetujui',
              rejected: 'Ditolak',
              fulfilled: 'Selesai (Barang Diserahkan)',
              cancelled: 'Dibatalkan'
            };
          %>
          <span class="badge <%= statusColors[header.status] || 'bg-gray-100 text-gray-800' %>" style="padding: 0.4rem 0.8rem; font-size: 0.875rem;">
            <%= statusLabels[header.status] || header.status %>
          </span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <div>
            <p class="text-xs text-muted-foreground mb-1">Nomor Permintaan</p>
            <p class="font-mono font-semibold text-sm"><%= header.request_number %></p>
          </div>
          <div>
            <p class="text-xs text-muted-foreground mb-1">Tanggal Permintaan</p>
            <p class="font-medium text-sm"><%= new Date(header.request_date).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) %></p>
          </div>
          <div>
            <p class="text-xs text-muted-foreground mb-1">Dibuat Pada</p>
            <p class="font-medium text-sm"><%= new Date(header.created_at).toLocaleString('id-ID', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
          </div>
          <div>
            <p class="text-xs text-muted-foreground mb-1">Pemohon</p>
            <p class="font-medium text-sm"><%= header.pemohon_name %></p>
            <p class="text-xs text-muted-foreground"><%= header.pemohon_nip %></p>
          </div>
          <div>
            <p class="text-xs text-muted-foreground mb-1">Unit Kerja</p>
            <p class="font-medium text-sm"><%= header.pemohon_unit || '-' %></p>
          </div>
          <% if (header.approver_name) { %>
            <div>
              <p class="text-xs text-muted-foreground mb-1">Disetujui Oleh</p>
              <p class="font-medium text-sm"><%= header.approver_name %></p>
              <% if (header.approved_at) { %>
                <p class="text-xs text-muted-foreground">
                  <%= new Date(header.approved_at).toLocaleString('id-ID', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                </p>
              <% } %>
            </div>
          <% } %>
        </div>
      </div>

      <!-- ===== Card 2: Daftar Item ===== -->
      <div class="card p-6">
        <div class="flex items-center justify-between mb-4">
          <div>
            <h2 class="text-base font-semibold">Barang yang Diminta</h2>
            <p class="text-sm text-muted-foreground mt-1">
              Total <strong><%= totalItems %></strong> jenis barang &middot; total kuantitas <strong><%= totalQuantity %></strong>
            </p>
          </div>
        </div>

        <% if (details && details.length > 0) { %>
          <div class="overflow-x-auto">
            <table class="table w-full">
              <thead>
                <tr>
                  <th style="width: 50px">#</th>
                  <th>Kode</th>
                  <th>Nama Barang</th>
                  <th>Spesifikasi</th>
                  <th class="text-right" style="width: 100px">Jumlah</th>
                  <th style="width: 80px">Satuan</th>
                </tr>
              </thead>
              <tbody>
                <% details.forEach(function(d, idx) { %>
                  <tr>
                    <td><%= idx + 1 %></td>
                    <td class="font-mono text-xs"><%= d.item_code || '-' %></td>
                    <td class="font-medium"><%= d.item_name %></td>
                    <td class="text-sm text-muted-foreground">
                      <%= d.specification || '-' %>
                    </td>
                    <td class="text-right font-semibold"><%= d.quantity %></td>
                    <td class="text-sm"><%= d.item_unit || '-' %></td>
                  </tr>
                <% }); %>
              </tbody>
              <tfoot>
                <tr style="border-top: 2px solid var(--color-border)">
                  <td colspan="4" class="text-right font-semibold">Total Kuantitas:</td>
                  <td class="text-right font-semibold"><%= totalQuantity %></td>
                  <td></td>
                </tr>
              </tfoot>
            </table>
          </div>
        <% } else { %>
          <div class="p-8 text-center text-muted-foreground text-sm">
            Tidak ada detail item untuk permintaan ini.
          </div>
        <% } %>
      </div>

      <!-- ===== Card 3: Timeline Approval ===== -->
      <% if (approvals && approvals.length > 0) { %>
        <div class="card p-6">
          <div class="mb-4">
            <h2 class="text-base font-semibold">Riwayat Persetujuan</h2>
            <p class="text-sm text-muted-foreground mt-1">Keputusan yang telah diambil admin logistik</p>
          </div>

          <div class="space-y-4">
            <% approvals.forEach(function(a, idx) { %>
              <%
                const aColors = {
                  approved: 'border-blue-500 bg-blue-50 dark:bg-blue-950',
                  rejected: 'border-red-500 bg-red-50 dark:bg-red-950',
                  reverted: 'border-yellow-500 bg-yellow-50 dark:bg-yellow-950'
                };
                const aLabels = {
                  approved: 'Disetujui',
                  rejected: 'Ditolak',
                  reverted: 'Keputusan Dibatalkan'
                };
                const aIcons = {
                  approved: '<polyline points="20 6 9 17 4 12" />',
                  rejected: '<line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />',
                  reverted: '<polyline points="1 4 1 10 7 10" /><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10" />'
                };
              %>
              <div class="border-l-4 <%= aColors[a.status] || 'border-gray-400' %> p-4 rounded-r">
                <div class="flex items-start gap-3">
                  <div class="size-8 rounded-full bg-background flex items-center justify-center shrink-0 border">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <%- aIcons[a.status] || '' %>
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between flex-wrap gap-2">
                      <p class="font-semibold text-sm"><%= aLabels[a.status] || a.status %></p>
                      <p class="text-xs text-muted-foreground">
                        <%= new Date(a.action_date).toLocaleString('id-ID', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                      </p>
                    </div>
                    <p class="text-sm text-muted-foreground mt-1">
                      Oleh: <strong><%= a.approver_name %></strong> (<%= a.approver_nip %>)
                    </p>
                    <% if (a.notes) { %>
                      <div class="mt-2 p-3 bg-background rounded border text-sm">
                        <p class="text-xs text-muted-foreground mb-1">Catatan:</p>
                        <p><%= a.notes %></p>
                      </div>
                    <% } %>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      <% } else if (header.status === 'pending') { %>
        <!-- Belum ada keputusan: kasih info ke user -->
        <div class="card p-6 border-l-4 border-yellow-500 bg-yellow-50 dark:bg-yellow-950">
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-yellow-600 dark:text-yellow-400 mt-0.5 shrink-0">
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </svg>
            <div>
              <p class="font-semibold text-yellow-900 dark:text-yellow-100">Menunggu peninjauan admin logistik</p>
              <p class="text-sm text-yellow-700 dark:text-yellow-300 mt-1">
                Permintaan Anda sedang diproses. Anda dapat membatalkan atau mengedit permintaan ini selama statusnya masih "Menunggu".
              </p>
            </div>
          </div>
        </div>
      <% } %>

    </div>
  </main>

<%- include('../partials/footer') %>
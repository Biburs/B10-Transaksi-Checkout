<!--
  Fungsi: Form buat permintaan barang baru (untuk role pegawai)
  Variabel dari controller:
    - title           (string)  : "Buat Permintaan"
    - user            (string)  : nama user
    - userRole        (string)  : 'pegawai'
    - items           (array)   : daftar barang untuk dropdown
    - today           (string)  : tanggal hari ini (YYYY-MM-DD)
    - successNumber   (string?) : request_number kalau baru sukses submit
    - error           (string?) : pesan error validasi
    - formData        (object?) : data form sebelumnya (kalau ada error)
-->

<%- include('../../partials/head', { title: title }) %>

<body class="bg-background">
  <%- include('../../partials/sidebar', { user: user, userRole: userRole, activeMenu: 'buat' }) %>

  <main id="content">
    <%- include('../../partials/topbar', {
      pageTitle: 'Buat Permintaan Baru',
      pageSubtitle: 'Ajukan permintaan barang habis pakai untuk kebutuhan kerja Anda'
    }) %>

    <div class="p-6 space-y-6 max-w-5xl">

      <!-- ===== Banner Sukses ===== -->
      <% if (successNumber) { %>
        <div class="card p-4 border-l-4 border-green-500 bg-green-50 dark:bg-green-950">
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600 dark:text-green-400 mt-0.5 shrink-0">
              <polyline points="20 6 9 17 4 12" />
            </svg>
            <div>
              <p class="font-semibold text-green-900 dark:text-green-100">Permintaan berhasil dibuat!</p>
              <p class="text-sm text-green-700 dark:text-green-300 mt-1">
                Nomor permintaan: <span class="font-mono font-semibold"><%= successNumber %></span>.
                Status: Menunggu persetujuan admin logistik.
              </p>
              <div class="mt-3 flex gap-2">
                <a href="/home" class="text-sm text-green-700 dark:text-green-300 hover:underline">← Kembali ke Dashboard</a>
              </div>
            </div>
          </div>
        </div>
      <% } %>

      <!-- ===== Banner Error ===== -->
      <% if (error) { %>
        <div class="card p-4 border-l-4 border-red-500 bg-red-50 dark:bg-red-950">
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-red-600 dark:text-red-400 mt-0.5 shrink-0">
              <circle cx="12" cy="12" r="10" />
              <line x1="12" y1="8" x2="12" y2="12" />
              <line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            <div>
              <p class="font-semibold text-red-900 dark:text-red-100">Periksa kembali isian form Anda</p>
              <p class="text-sm text-red-700 dark:text-red-300 mt-1"><%= error %></p>
            </div>
          </div>
        </div>
      <% } %>

      <!-- ===== Form Permintaan ===== -->
      <form action="/permintaan/baru" method="POST" id="formPermintaan">

        <!-- Card 1: Informasi Permintaan -->
        <div class="card p-6 mb-6">
          <h2 class="text-base font-semibold mb-1">Informasi Permintaan</h2>
          <p class="text-sm text-muted-foreground mb-4">
            Nomor permintaan akan otomatis dibuat dengan format <code class="text-xs">REQ-YYYYMMDD-NNN</code>
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="request_date" class="label mb-2">Tanggal Permintaan <span class="text-red-500">*</span></label>
              <input
                type="date"
                id="request_date"
                name="request_date"
                class="input w-full"
                value="<%= (formData && formData.request_date) ? formData.request_date : today %>"
                required
              />
            </div>
            <div>
              <label class="label mb-2">Pemohon</label>
              <input
                type="text"
                class="input w-full"
                value="<%= user %>"
                readonly
                style="background-color: var(--color-muted); cursor: not-allowed"
              />
            </div>
          </div>
        </div>

        <!-- Card 2: Daftar Item -->
        <div class="card p-6 mb-6">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="text-base font-semibold">Daftar Barang yang Diminta</h2>
              <p class="text-sm text-muted-foreground mt-1">Tambahkan minimal 1 barang. Spesifikasi opsional.</p>
            </div>
          </div>

          <div class="overflow-x-auto">
            <table class="table w-full" id="tableItems">
              <thead>
                <tr>
                  <th style="width: 50px">#</th>
                  <th style="min-width: 280px">Barang <span class="text-red-500">*</span></th>
                  <th style="width: 130px">Jumlah <span class="text-red-500">*</span></th>
                  <th style="min-width: 200px">Spesifikasi</th>
                  <th style="width: 80px" class="text-right">Aksi</th>
                </tr>
              </thead>
              <tbody id="item-rows">
                <% 
                  // Kalau ada error, re-render baris yang sudah diisi user
                  // Kalau bukan error, render 1 baris kosong
                  const rowsToRender = (formData && formData.items && formData.items.length > 0)
                    ? formData.items
                    : [null]; // null = baris kosong
                  rowsToRender.forEach(function(row, idx) { 
                %>
                  <tr class="item-row">
                    <td class="row-number"><%= idx + 1 %></td>
                    <td>
                      <select name="item_id" class="select w-full" required>
                        <option value="">-- Pilih barang --</option>
                        <% items.forEach(function(opt) { %>
                          <option 
                            value="<%= opt.id %>" 
                            <%= (row && row.item_id == opt.id) ? 'selected' : '' %>
                          >
                            <%= opt.code %> &middot; <%= opt.name %> (<%= opt.unit %>)
                          </option>
                        <% }); %>
                      </select>
                    </td>
                    <td>
                      <input
                        type="number"
                        name="quantity"
                        class="input w-full"
                        min="1"
                        value="<%= row ? row.quantity : '' %>"
                        required
                      />
                    </td>
                    <td>
                      <input
                        type="text"
                        name="specification"
                        class="input w-full"
                        placeholder="Opsional"
                        value="<%= row && row.specification ? row.specification : '' %>"
                      />
                    </td>
                    <td class="text-right">
                      <button
                        type="button"
                        class="btn-outline btn-remove"
                        onclick="removeRow(this)"
                        title="Hapus baris"
                        style="padding: 0.4rem 0.6rem"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <line x1="18" y1="6" x2="6" y2="18" />
                          <line x1="6" y1="6" x2="18" y2="18" />
                        </svg>
                      </button>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>

          <div class="mt-4">
            <button type="button" class="btn-outline" onclick="addRow()">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
                <path d="M12 5v14" /><path d="M5 12h14" />
              </svg>
              Tambah Barang
            </button>
          </div>
        </div>

        <!-- Action Bar -->
        <div class="flex items-center justify-end gap-3">
          <a href="/home" class="btn-outline">Batal</a>
          <button type="submit" class="btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
              <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" />
              <polyline points="17 21 17 13 7 13 7 21" />
              <polyline points="7 3 7 8 15 8" />
            </svg>
            Simpan Permintaan
          </button>
        </div>

      </form>

    </div>
  </main>

  <!-- ===== Script: Dynamic Add/Remove Row ===== -->
  <script>
    function addRow() {
      const tbody = document.getElementById("item-rows");
      const firstRow = tbody.querySelector(".item-row");
      const clone = firstRow.cloneNode(true);

      // Reset nilai-nilai input pada clone
      clone.querySelector('select[name="item_id"]').value = "";
      clone.querySelector('input[name="quantity"]').value = "";
      clone.querySelector('input[name="specification"]').value = "";

      tbody.appendChild(clone);
      renumberRows();
    }

function removeRow(btn) {
      const rows = document.querySelectorAll(".item-row");
      if (rows.length <= 1) {
        document.dispatchEvent(new CustomEvent("basecoat:toast", {
          detail: {
            config: {
              category: "warning",
              title: "Tidak bisa dihapus",
              description: "Minimal 1 baris barang harus ada"
            }
          }
        }));
        return;
      }
      btn.closest(".item-row").remove();
      renumberRows();
    }

    function renumberRows() {
      document.querySelectorAll(".item-row").forEach(function (row, idx) {
        row.querySelector(".row-number").textContent = idx + 1;
      });
    }

    // Hilangkan banner sukses dari URL setelah 5 detik (UX bersih)
    if (window.location.search.includes("success=")) {
      setTimeout(function () {
        const url = new URL(window.location);
        url.searchParams.delete("success");
        window.history.replaceState({}, "", url);
      }, 5000);
    }
  </script>

<%- include('../../partials/footer') %>
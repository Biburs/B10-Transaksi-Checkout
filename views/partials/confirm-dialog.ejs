<!--
  Reusable Confirm Dialog
  ========================
  Modal konfirmasi yang dipanggil otomatis saat user klik tombol
  yang punya atribut data-confirm-title.

  CARA PAKAI:
    <form action="..." method="POST">
      <button type="submit"
              data-confirm-title="Judul"
              data-confirm-message="Pesan konfirmasi"
              data-confirm-label="Ya, Lanjutkan"
              data-confirm-variant="destructive">
        Tombol
      </button>
    </form>

  Variant tersedia: "destructive" (merah), "success" (hijau), default (biru)
-->

<style>
  /* === Ikon wrap === */
  .cd-icon-destructive {
    background-color: rgb(254, 226, 226);
    color: rgb(220, 38, 38);
  }
  .dark .cd-icon-destructive {
    background-color: rgb(69, 10, 10);
    color: rgb(248, 113, 113);
  }

  .cd-icon-success {
    background-color: rgb(220, 252, 231);
    color: rgb(22, 163, 74);
  }
  .dark .cd-icon-success {
    background-color: rgb(5, 46, 22);
    color: rgb(74, 222, 128);
  }

  .cd-icon-default {
    background-color: rgb(219, 234, 254);
    color: rgb(37, 99, 235);
  }
  .dark .cd-icon-default {
    background-color: rgb(23, 37, 84);
    color: rgb(96, 165, 250);
  }

  /* === Tombol konfirmasi === */
  .cd-btn-destructive {
    background-color: rgb(220, 38, 38);
    color: white;
    transition: background-color 0.15s;
  }
  .cd-btn-destructive:hover {
    background-color: rgb(185, 28, 28);
  }

  .cd-btn-success {
    background-color: rgb(22, 163, 74);
    color: white;
    transition: background-color 0.15s;
  }
  .cd-btn-success:hover {
    background-color: rgb(21, 128, 61);
  }
</style>

<dialog id="confirmDialog"
        class="rounded-lg shadow-2xl backdrop:bg-black/60 p-0 max-w-md w-[90%]"
        style="border: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); margin: 0;">
  <div class="card p-6 bg-card text-foreground text-center">

    <!-- Ikon di atas (akan diisi script sesuai variant) -->
    <div id="confirmDialogIconWrap" class="mx-auto mb-4 flex items-center justify-center w-14 h-14 rounded-full">
      <span id="confirmDialogIcon"></span>
    </div>

    <h3 id="confirmDialogTitle" class="text-lg font-semibold mb-2">Konfirmasi</h3>
    <p id="confirmDialogMessage" class="text-sm text-muted-foreground mb-6">Anda yakin?</p>
    <div class="flex justify-center gap-2">
      <button type="button" id="confirmDialogCancel" class="btn-outline">Batal</button>
      <button type="button" id="confirmDialogConfirm" class="btn">Konfirmasi</button>
    </div>
  </div>
</dialog>

<script>
  (function () {
    const dialog = document.getElementById("confirmDialog");
    if (!dialog) return;

    const titleEl = document.getElementById("confirmDialogTitle");
    const messageEl = document.getElementById("confirmDialogMessage");
    const iconWrap = document.getElementById("confirmDialogIconWrap");
    const iconEl = document.getElementById("confirmDialogIcon");
    const cancelBtn = document.getElementById("confirmDialogCancel");
    const confirmBtn = document.getElementById("confirmDialogConfirm");

    let pendingForm = null;

    const ICONS = {
      destructive: {
        wrapClass: "cd-icon-destructive",
        btnClass: "btn cd-btn-destructive",
        svg: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>'
      },
      success: {
        wrapClass: "cd-icon-success",
        btnClass: "btn cd-btn-success",
        svg: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>'
      },
      default: {
        wrapClass: "cd-icon-default",
        btnClass: "btn",
        svg: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>'
      }
    };

    cancelBtn.addEventListener("click", function () {
      dialog.close();
      pendingForm = null;
    });

    confirmBtn.addEventListener("click", function () {
      const form = pendingForm;
      dialog.close();
      pendingForm = null;
      if (form) form.submit();
    });

    // Tutup kalau klik di backdrop (di luar card)
    dialog.addEventListener("click", function (event) {
      if (event.target === dialog) {
        dialog.close();
        pendingForm = null;
      }
    });

    // Auto-attach listener ke semua tombol dengan data-confirm-title
    document.querySelectorAll("[data-confirm-title]").forEach(function (btn) {
      btn.addEventListener("click", function (event) {
        event.preventDefault();

        const variant = btn.dataset.confirmVariant || "default";
        const cfg = ICONS[variant] || ICONS.default;

        titleEl.textContent = btn.dataset.confirmTitle || "Konfirmasi";
        messageEl.textContent = btn.dataset.confirmMessage || "Anda yakin?";
        confirmBtn.textContent = btn.dataset.confirmLabel || "Konfirmasi";

        iconWrap.className = "mx-auto mb-4 flex items-center justify-center w-14 h-14 rounded-full " + cfg.wrapClass;
        iconEl.innerHTML = cfg.svg;
        confirmBtn.className = cfg.btnClass;

        pendingForm = btn.closest("form");
        dialog.showModal();
      });
    });
  })();
</script>